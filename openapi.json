{
  "openapi": "3.0.0",
  "info": {
    "title": "Journalists Service",
    "description": "Manages journalist profiles, outlet affiliations, and engagement tracking.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3020"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "DiscoveredJournalist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "journalistName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "entityType": {
            "type": "string",
            "enum": [
              "individual",
              "organization"
            ]
          },
          "relevanceScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "whyRelevant": {
            "type": "string"
          },
          "whyNotRelevant": {
            "type": "string"
          },
          "articleUrls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isNew": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "journalistName",
          "firstName",
          "lastName",
          "entityType",
          "relevanceScore",
          "whyRelevant",
          "whyNotRelevant",
          "articleUrls",
          "isNew"
        ]
      },
      "DiscoverJournalistsResponse": {
        "type": "object",
        "properties": {
          "journalists": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DiscoveredJournalist"
            }
          },
          "totalArticlesSearched": {
            "type": "number"
          },
          "totalNamesExtracted": {
            "type": "number"
          },
          "totalJournalistsStored": {
            "type": "number"
          }
        },
        "required": [
          "journalists",
          "totalArticlesSearched",
          "totalNamesExtracted",
          "totalJournalistsStored"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "DiscoverJournalistsRequest": {
        "type": "object",
        "properties": {
          "outletId": {
            "type": "string",
            "format": "uuid"
          },
          "maxArticles": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30,
            "default": 15
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 1
          },
          "acceptanceThreshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "default": 70
          }
        },
        "required": [
          "outletId"
        ]
      },
      "ResolvedJournalist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "journalistName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "entityType": {
            "type": "string",
            "enum": [
              "individual",
              "organization"
            ]
          },
          "relevanceScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "whyRelevant": {
            "type": "string"
          },
          "whyNotRelevant": {
            "type": "string"
          },
          "articleUrls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "journalistName",
          "firstName",
          "lastName",
          "entityType",
          "relevanceScore",
          "whyRelevant",
          "whyNotRelevant",
          "articleUrls"
        ]
      },
      "ResolveJournalistsResponse": {
        "type": "object",
        "properties": {
          "journalists": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResolvedJournalist"
            }
          },
          "cached": {
            "type": "boolean"
          }
        },
        "required": [
          "journalists",
          "cached"
        ]
      },
      "ResolveJournalistsRequest": {
        "type": "object",
        "properties": {
          "outletId": {
            "type": "string",
            "format": "uuid"
          },
          "maxArticles": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30,
            "default": 15
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 1
          },
          "acceptanceThreshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "default": 70
          }
        },
        "required": [
          "outletId"
        ]
      },
      "CampaignOutletJournalist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "journalistId": {
            "type": "string",
            "format": "uuid"
          },
          "campaignId": {
            "type": "string",
            "format": "uuid"
          },
          "outletId": {
            "type": "string",
            "format": "uuid"
          },
          "orgId": {
            "type": "string",
            "format": "uuid"
          },
          "brandId": {
            "type": "string",
            "format": "uuid"
          },
          "featureSlug": {
            "type": "string",
            "nullable": true
          },
          "relevanceScore": {
            "type": "string"
          },
          "whyRelevant": {
            "type": "string"
          },
          "whyNotRelevant": {
            "type": "string"
          },
          "articleUrls": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "journalistName": {
            "type": "string"
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "entityType": {
            "type": "string",
            "enum": [
              "individual",
              "organization"
            ]
          }
        },
        "required": [
          "id",
          "journalistId",
          "campaignId",
          "outletId",
          "orgId",
          "brandId",
          "featureSlug",
          "relevanceScore",
          "whyRelevant",
          "whyNotRelevant",
          "articleUrls",
          "createdAt",
          "journalistName",
          "firstName",
          "lastName",
          "entityType"
        ]
      },
      "CampaignOutletJournalistsResponse": {
        "type": "object",
        "properties": {
          "campaignJournalists": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CampaignOutletJournalist"
            }
          }
        },
        "required": [
          "campaignJournalists"
        ]
      },
      "Journalist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "outletId": {
            "type": "string",
            "format": "uuid"
          },
          "entityType": {
            "type": "string",
            "enum": [
              "individual",
              "organization"
            ]
          },
          "journalistName": {
            "type": "string"
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "outletId",
          "entityType",
          "journalistName",
          "firstName",
          "lastName",
          "createdAt",
          "updatedAt"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string"
                    },
                    "service": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "status",
                    "timestamp",
                    "service"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/journalists/discover": {
      "post": {
        "summary": "Discover relevant journalists for a brand on an outlet via article search + LLM scoring",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DiscoverJournalistsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Discovered journalists with relevance scores",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoverJournalistsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Upstream service error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/journalists/resolve": {
      "post": {
        "summary": "Resolve journalists for a campaign+outlet: discover if needed, score, and return",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResolveJournalistsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolved journalists sorted by relevance score",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResolveJournalistsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Upstream service error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/campaign-outlet-journalists": {
      "get": {
        "summary": "Get journalists associated with a campaign, optionally filtered by outlet",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "campaign_id",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "outlet_id",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign journalists with journalist details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignOutletJournalistsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/internal/journalists/by-ids": {
      "get": {
        "summary": "Batch lookup journalists by IDs",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "ids",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Journalists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "journalists": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Journalist"
                      }
                    }
                  },
                  "required": [
                    "journalists"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}